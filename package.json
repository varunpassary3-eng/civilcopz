{
  "name": "civilcopz",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\"",
    "orchestrate": "node scripts/orchestrator.js",
    "stabilize": "npm install && npm run rw-install && npx prisma generate --schema=backend/prisma/schema.prisma",
    "start": "npm --workspace backend start",
    "install-all": "npm install && npm run rw-install && npm run rw-setup",
    "rw-install": "npm --workspace backend install && npm --workspace frontend install",
    "validate:staging": "node scripts/staging-readiness.js",
    "validate:evidence": "node backend/scripts/evidence-consistency-check.js",
    "deploy:staging": "node scripts/gcp/deploy-staging.js",
    "validate:gcp-mirror": "node scripts/gcp/validate-gcp-mirror.js",
    "validate:observability": "node scripts/gcp/validate-observability.js",
    "validate:security": "node scripts/validate-security.js",
    "validate:secrets": "node scripts/gcp/validate-secrets.js",
    "chaos": "node scripts/gcp/run-chaos.js",
    "test:cve": "jest --config jest.config.js",
    "lint": "eslint . --ext .js,.vue",
    "test:live": "node test-live/scripts/run_full_test.js",
    "test:load:10k": "node test-live/scripts/load_test_10k.js",
    "generate:audit": "node test-live/scripts/generate_audit_report.js"
  },
  "overrides": {
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.3",
    "dotenv": "^16.3.1",
    "zod": "^3.23.8",
    "pdf-parse": "^1.1.1",
    "jest-util": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "@eslint/js": "^8.57.0"
  }
}
