# Database Configuration
DB_NAME=civilcopz
DB_USER=civilcopz_user
DB_PASSWORD=your_secure_db_password_here

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRY=24h

# Application Configuration
NODE_ENV=production
BACKEND_PORT=4000
FRONTEND_PORT=5173

# Database URL
DATABASE_URL=postgresql://civilcopz_user:secure_password_123@localhost:5432/civilcopz

# Optional: External Database (for cloud deployment)
# DATABASE_URL=postgresql://user:password@host:5432/database
ALLOW_MOCK_DB_FALLBACK=false

# Optional: Redis for session storage (future enhancement)
# REDIS_URL=redis://redis:6379

# Optional: File Storage (future enhancement)
# AWS_S3_BUCKET=your-s3-bucket
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Optional: Email Configuration (future enhancement)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Monitoring (Production Grade)
# SENTRY_DSN=your-sentry-dsn
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX_YOUR_WEBHOOK_URL
# ALERT_EMAIL=admin@civilcopz.gov
# LOG_LEVEL=info

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker Configuration
WORKER_MODE=server
START_WORKER=true

# Legacy variables (for backward compatibility)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# PORT=4000

# Frontend
VITE_API_URL=http://localhost:4000/api
