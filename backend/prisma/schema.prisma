generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  role     UserRole @default(consumer)
  createdAt DateTime @default(now())
  cases    Case[]   @relation("ReporterCases")
  auditLogs AuditLog[]

  @@map("users")
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String
  totalCases  Int      @default(0)
  rating      Float    @default(0)
  cases       Case[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("companies")
  @@index([name])
}

model Case {
  id          String   @id @default(cuid())
  title       String
  description String
  company     String
  category    String
  jurisdiction String
  status      CaseStatus @default(Pending)
  filePath    String?

  // AI Classification Fields
  aiCategory        String?
  aiSeverity        String?
  aiConfidence      Float?
  aiKeyIssues       String[]  // Array of key issues identified
  aiSuggestedAction String?
  aiRelevantLaws    String[]  // Array of relevant laws/sections
  aiProcessedAt     DateTime?
  aiProcessingError String?

  createdAt   DateTime @default(now())
  reporter    User?    @relation("ReporterCases", fields: [reporterId], references: [id])
  reporterId  String?
  
  companyRef  Company? @relation(fields: [companyId], references: [id])
  companyId   String?

  timeline    CaseTimeline[]

  @@map("cases")
  @@index([company])
  @@index([status])
  @@index([createdAt])
  @@index([aiCategory])
  @@index([aiSeverity])
}

model AdvisoryService {
  id              String   @id @default(cuid())
  name            String
  type            ServiceType @default(ADVISORY)
  description     String
  category        String   // Matches Case.category for integration
  specialization  String[]
  contactEmail    String?
  contactPhone    String?
  website         String?
  isProBono       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("advisory_services")
  @@index([category])
  @@index([type])
}

enum CaseStatus {
  Pending
  Review
  Resolved
}

enum UserRole {
  consumer
  admin
}

enum ServiceType {
  ADVISORY
  LEGAL_AID
  PRIVATE_ADVOCATE
}

model CaseTimeline {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  action    String
  status    CaseStatus
  timestamp DateTime @default(now())

  @@map("case_timeline")
  @@index([caseId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String?
  timestamp DateTime @default(now())

  @@map("audit_logs")
}

