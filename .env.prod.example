# CivilCOPZ National Scale Production Environment Variables
# Copy this file to .env.prod and fill in the actual values

# Database Configuration
DB_PASSWORD=your_secure_db_password_here
DB_NAME=civilcopz
DB_USER=civilcopz_user

# JWT Configuration
JWT_SECRET=your_256_bit_jwt_secret_here
JWT_EXPIRY=24h

# AI Service Configuration
OPENAI_API_KEY=your_openai_api_key_here
AZURE_AI_ENDPOINT=your_azure_ai_endpoint_here
AZURE_AI_KEY=your_azure_ai_key_here

# Monitoring Configuration
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password_here

# Application Configuration
NODE_ENV=production
BACKEND_PORT=4000

# SSL/TLS Configuration (for production)
SSL_CERT_PATH=/etc/nginx/ssl/civilcopz.crt
SSL_KEY_PATH=/etc/nginx/ssl/civilcopz.key

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# Load Balancer Configuration
UPSTREAM_SERVERS=backend-1:4000 backend-2:4000 backend-3:4000