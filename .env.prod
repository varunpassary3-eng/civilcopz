# CivilCOPZ Production Environment Configuration
# CRITICAL: Never commit this file to version control
# Generate strong random values for all secrets

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# ==========================================
# DATABASE CONFIGURATION (PRODUCTION ONLY)
# ==========================================
# WARNING: Use separate production database - NEVER reuse development DB
DATABASE_URL=postgresql://civilcopz_prod_user:CHANGE_THIS_STRONG_PASSWORD@prod-db-host:5432/civilcopz_prod
DB_HOST=prod-db-host
DB_PORT=5432
DB_NAME=civilcopz_prod
DB_USER=civilcopz_prod_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_SSL=true
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# Read replicas for scaling (optional)
DB_READ_HOSTS=prod-db-replica-1:5432,prod-db-replica-2:5432

# ==========================================
# REDIS CONFIGURATION (PRODUCTION ONLY)
# ==========================================
REDIS_HOST=prod-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_TLS=true
REDIS_MAX_CONNECTIONS=50

# Redis cluster for scaling (optional)
REDIS_READ_HOSTS=prod-redis-replica-1:6379,prod-redis-replica-2:6379

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# JWT: Generate 256-bit secret (openssl rand -hex 32)
JWT_SECRET=CHANGE_THIS_256_BIT_RANDOM_SECRET_64_CHARS_MINIMUM
JWT_EXPIRY=12h
JWT_REFRESH_EXPIRY=7d

# Session security
SESSION_SECRET=CHANGE_THIS_ANOTHER_256_BIT_RANDOM_SECRET
SESSION_MAX_AGE=86400000

# CORS configuration (restrict to your domain)
CORS_ORIGIN=https://civilcopz.com,https://www.civilcopz.com
CORS_CREDENTIALS=true

# ==========================================
# AI SERVICE CONFIGURATION
# ==========================================
OPENAI_API_KEY=CHANGE_THIS_OPENAI_API_KEY
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT=30000

# Azure AI (fallback/backup)
AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_AI_KEY=CHANGE_THIS_AZURE_AI_KEY
AZURE_AI_MODEL=gpt-4
AZURE_AI_VERSION=2023-12-01-preview

# ==========================================
# FILE UPLOAD CONFIGURATION
# ==========================================
UPLOAD_PATH=/var/app/civilcopz/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# ==========================================
# MONITORING & LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/var/log/civilcopz/app.log

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9091

# ==========================================
# EMAIL CONFIGURATION (for notifications)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@civilcopz.com
SMTP_PASS=CHANGE_THIS_APP_PASSWORD
EMAIL_FROM=noreply@civilcopz.com

# ==========================================
# EXTERNAL SERVICE INTEGRATIONS
# ==========================================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Uptime monitoring
UPTIME_ROBOT_API_KEY=your-uptime-robot-key

# ==========================================
# BACKUP CONFIGURATION
# ==========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=civilcopz-prod-backups
BACKUP_S3_REGION=us-east-1

# ==========================================
# PERFORMANCE CONFIGURATION
# ==========================================
# Cache settings
CACHE_TTL=3600
CACHE_MAX_MEMORY=512mb

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Connection pooling
POOL_MIN=2
POOL_MAX=20
POOL_IDLE_TIMEOUT=30000

# ==========================================
# LEGAL & COMPLIANCE
# ==========================================
# Data retention (in days)
AUDIT_LOG_RETENTION=2555
CASE_DATA_RETENTION=2555
USER_DATA_RETENTION=2555

# GDPR compliance
DATA_ENCRYPTION_KEY=CHANGE_THIS_256_BIT_ENCRYPTION_KEY
HASH_SALT_ROUNDS=12

# ==========================================
# DEPLOYMENT CONFIGURATION
# ==========================================
DEPLOY_ENV=production
DEPLOY_VERSION=1.0.0
DEPLOY_TIMESTAMP=2024-01-01T00:00:00Z

# ==========================================
# EMERGENCY CONTACTS
# ==========================================
ALERT_EMAIL=alerts@civilcopz.com
ADMIN_EMAIL=admin@civilcopz.com
SUPPORT_EMAIL=support@civilcopz.com

# ==========================================
# SECURITY CHECKLIST (SET TO TRUE AFTER VERIFICATION)
# ==========================================
SECURITY_AUDIT_COMPLETED=false
PENETRATION_TEST_COMPLETED=false
LEGAL_REVIEW_COMPLETED=false
COMPLIANCE_CHECK_COMPLETED=false